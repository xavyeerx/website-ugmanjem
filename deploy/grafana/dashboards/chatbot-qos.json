{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Chat Requests / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(chatbot_chat_requests_total[1m]) * 60",
          "legendFormat": "{{ status }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm" }
      }
    },
    {
      "title": "End-to-End Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(chatbot_chat_e2e_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(chatbot_chat_e2e_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(chatbot_chat_e2e_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Error Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(chatbot_chat_requests_total{status!=\"success\"}[5m])) / sum(rate(chatbot_chat_requests_total[5m])) * 100",
          "legendFormat": "error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "Pipeline Latency Breakdown",
      "description": "Avg latency per RAG pipeline stage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(chatbot_retrieval_duration_seconds_sum[5m]) / rate(chatbot_retrieval_duration_seconds_count[5m])",
          "legendFormat": "Retrieval (ChromaDB)",
          "refId": "A"
        },
        {
          "expr": "rate(chatbot_live_context_duration_seconds_sum[5m]) / rate(chatbot_live_context_duration_seconds_count[5m])",
          "legendFormat": "Live Context (Supabase)",
          "refId": "B"
        },
        {
          "expr": "rate(chatbot_generation_duration_seconds_sum[5m]) / rate(chatbot_generation_duration_seconds_count[5m])",
          "legendFormat": "Generation (Gemini)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Generation Latency Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(chatbot_generation_duration_seconds_bucket[5m])",
          "legendFormat": "{{ le }}",
          "refId": "A",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Retrieval Quality (Avg Distance)",
      "description": "Lower distance = more relevant retrieval. Track retrieval quality over time.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "chatbot_retrieval_distance_sum / chatbot_retrieval_distance_count",
          "legendFormat": "avg distance",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" }
      }
    },
    {
      "title": "Live Context Cache Hit Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "rate(chatbot_live_context_cache_hits_total[5m]) / (rate(chatbot_live_context_cache_hits_total[5m]) + rate(chatbot_live_context_cache_misses_total[5m])) * 100",
          "legendFormat": "hit rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "Gemini API Retries & Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "rate(chatbot_generation_retries_total[5m]) * 60",
          "legendFormat": "retries/min",
          "refId": "A"
        },
        {
          "expr": "rate(chatbot_generation_errors_total[5m]) * 60",
          "legendFormat": "errors/min ({{ error_type }})",
          "refId": "B"
        }
      ]
    },
    {
      "title": "In-Flight Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "chatbot_http_requests_in_progress",
          "legendFormat": "{{ endpoint }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Input / Output Characters (Avg)",
      "description": "Average prompt size and response size per request",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [
        {
          "expr": "chatbot_generation_input_chars_sum / chatbot_generation_input_chars_count",
          "legendFormat": "avg input chars",
          "refId": "A"
        },
        {
          "expr": "chatbot_generation_output_chars_sum / chatbot_generation_output_chars_count",
          "legendFormat": "avg output chars",
          "refId": "B"
        }
      ]
    },
    {
      "title": "HTTP Request Rate by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        {
          "expr": "rate(chatbot_http_requests_total[1m]) * 60",
          "legendFormat": "{{ method }} {{ endpoint }} {{ status }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm" }
      }
    },
    {
      "title": "Resource Utilization — CPU, Memory, Network, Disk (per Container & Host VPS)",
      "type": "text",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 32 },
      "options": {
        "mode": "html",
        "content": "<div style=\"padding:8px 0\"><h2 style=\"margin:0;color:#73BF69\">Resource Utilization</h2><p style=\"margin:4px 0 0;color:#8e8e8e\">CPU, Memory, Network, dan Disk usage per container dan host VPS</p></div>"
      }
    },
    {
      "title": "Container CPU Usage (%)",
      "description": "CPU usage percentage per Docker container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=\"\"}[1m])) by (container_label_com_docker_compose_service) * 100",
          "legendFormat": "{{ container_label_com_docker_compose_service }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"anjem-.*\"}[1m])) by (name) * 100",
          "legendFormat": "{{ name }}",
          "refId": "B"
        },
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\"/system.slice/docker-.*\"}[1m])) by (id) * 100",
          "legendFormat": "{{ id }}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0 }
      }
    },
    {
      "title": "Container Memory Usage",
      "description": "Memory usage per Docker container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{container_label_com_docker_compose_service!=\"\"} / 1024 / 1024",
          "legendFormat": "{{ container_label_com_docker_compose_service }}",
          "refId": "A"
        },
        {
          "expr": "container_memory_usage_bytes{name=~\"anjem-.*\"} / 1024 / 1024",
          "legendFormat": "{{ name }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      }
    },
    {
      "title": "Host CPU Usage (%)",
      "description": "Overall VPS CPU utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 43 },
      "targets": [
        {
          "expr": "(1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))) * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "Host Memory Usage (%)",
      "description": "Overall VPS RAM utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 43 },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Host Disk Usage (%)",
      "description": "VPS disk utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 43 },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
          "legendFormat": "Disk %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Container Network I/O",
      "description": "Network receive/transmit per container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{container_label_com_docker_compose_service!=\"\"}[1m])",
          "legendFormat": "{{ container_label_com_docker_compose_service }} RX",
          "refId": "A"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service!=\"\"}[1m])",
          "legendFormat": "{{ container_label_com_docker_compose_service }} TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Container Memory Breakdown",
      "description": "Memory per container as a stacked bar",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{container_label_com_docker_compose_service!=\"\"} / 1024 / 1024",
          "legendFormat": "{{ container_label_com_docker_compose_service }}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      }
    },
    {
      "title": "Reliability & Availability — Success Rate, Uptime, Error Tracking",
      "type": "text",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 59 },
      "options": {
        "mode": "html",
        "content": "<div style=\"padding:8px 0\"><h2 style=\"margin:0;color:#FF9830\">Reliability & Availability</h2><p style=\"margin:4px 0 0;color:#8e8e8e\">Success rate, uptime, error tracking, dan service availability</p></div>"
      }
    },
    {
      "title": "Chat Success Rate (Availability %)",
      "description": "Percentage of successful chat responses — key SLA metric",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 62 },
      "targets": [
        {
          "expr": "sum(rate(chatbot_chat_requests_total{status=\"success\"}[5m])) / sum(rate(chatbot_chat_requests_total[5m])) * 100",
          "legendFormat": "availability %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "title": "Success Rate Over Time",
      "description": "Chat success rate trend — tracks reliability over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 62 },
      "targets": [
        {
          "expr": "sum(rate(chatbot_chat_requests_total{status=\"success\"}[5m])) / sum(rate(chatbot_chat_requests_total[5m])) * 100",
          "legendFormat": "success rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "title": "Error Breakdown by Type",
      "description": "Errors categorized: rate_limited vs other failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 62 },
      "targets": [
        {
          "expr": "rate(chatbot_chat_requests_total{status=\"error\"}[5m]) * 60",
          "legendFormat": "general errors/min",
          "refId": "A"
        },
        {
          "expr": "rate(chatbot_chat_requests_total{status=\"rate_limited\"}[5m]) * 60",
          "legendFormat": "rate limited/min",
          "refId": "B"
        },
        {
          "expr": "rate(chatbot_retrieval_errors_total[5m]) * 60",
          "legendFormat": "retrieval errors/min",
          "refId": "C"
        },
        {
          "expr": "rate(chatbot_live_context_errors_total[5m]) * 60",
          "legendFormat": "live context errors/min",
          "refId": "D"
        }
      ]
    },
    {
      "title": "Total Requests (Cumulative)",
      "description": "Total requests processed since startup — shows overall load",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 70 },
      "targets": [
        {
          "expr": "sum(chatbot_chat_requests_total)",
          "legendFormat": "total chats",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Uptime (Backend Container)",
      "description": "How long the backend has been running",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 70 },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"chatbot-backend\"}",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "HTTP Error Codes Over Time",
      "description": "All non-200 HTTP responses tracked over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 70 },
      "targets": [
        {
          "expr": "rate(chatbot_http_requests_total{status!=\"200\"}[1m]) * 60",
          "legendFormat": "{{ status }} {{ endpoint }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["chatbot", "rag", "qos", "ugm-anjem"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "UGM Anjem Chatbot - QoS Dashboard",
  "uid": "ugm-anjem-qos",
  "version": 1
}
